{
  "openapi": "3.0.0",
  "info": {
    "title": "Team 13 Blog API",
    "version": "1.0.0",
    "description": "COP4331 Large Project - Spring 2026. All IDs are MongoDB ObjectIds (24-character hex strings). The 'creator' field is the username of the user making the request."
  },
  "servers": [
    { "url": "http://13.projectucf.software:3000" },
    { "url": "http://13.projectucf.software:5000" },
    { "url": "http://159.223.183.35:3000" },
    { "url": "http://159.223.183.35:5000" },
    { "url": "http://localhost:5000" }
  ],
  "components": {
    "schemas": {
      "Post": {
        "type": "object",
        "properties": {
          "_id": { "type": "string", "example": "663f1a2b4e12a84f5c9d0e7a", "description": "MongoDB ObjectId" },
          "title": { "type": "string", "example": "My First Blog Post" },
          "content": { "type": "string", "example": "This is the body of the blog post." },
          "creator": { "type": "string", "example": "johndoe", "description": "Username of the post author" },
          "scores": {
            "type": "object",
            "additionalProperties": { "type": "number", "minimum": 0, "maximum": 1 },
            "example": { "optimism": 0.7, "nsfw": 0.2 },
            "description": "Dynamic analyzer scores keyed by label"
          },
          "isAnalyzed": { "type": "boolean", "example": true },
          "tags": { "type": "array", "items": { "type": "string" }, "example": ["blog", "first", "post"], "description": "Auto-generated from title and content" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "Comment": {
        "type": "object",
        "properties": {
          "_id": { "type": "string", "example": "663f1b3c5f23b95g6d0e1f8b", "description": "MongoDB ObjectId" },
          "postId": { "type": "string", "example": "663f1a2b4e12a84f5c9d0e7a", "description": "MongoDB ObjectId of the parent post" },
          "creator": { "type": "string", "example": "janedoe", "description": "Username of the commenter" },
          "content": { "type": "string", "example": "Great post!" },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": { "type": "string" }
        }
      }
    }
  },
  "paths": {
    "/api/users/register": {
      "post": {
        "summary": "Register a new user",
        "description": "Creates a new account and sends a verification email. User must verify email before logging in.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": { "type": "string", "example": "johndoe" },
                  "email": { "type": "string", "example": "johndoe@example.com" },
                  "password": { "type": "string", "example": "mypassword123" }
                },
                "required": ["username", "email", "password"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Account created, verification email sent",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": { "type": "string", "example": "" },
                    "message": { "type": "string", "example": "Account created! Please check your email to verify." }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Username or email already in use",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" },
                "example": { "error": "Email already in use" }
              }
            }
          }
        }
      }
    },
    "/api/users/login": {
      "post": {
        "summary": "Log in",
        "description": "Authenticates a user. Returns error if credentials are wrong or email is not verified.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": { "type": "string", "example": "johndoe" },
                  "password": { "type": "string", "example": "mypassword123" }
                },
                "required": ["username", "password"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful (empty error string means success)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" },
                "example": { "error": "" }
              }
            }
          },
          "403": {
            "description": "Email not verified",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" },
                "example": { "error": "Please verify your email before logging in" }
              }
            }
          }
        }
      }
    },
    "/api/users/verify-email": {
      "get": {
        "summary": "Verify email address",
        "description": "Verifies a user's email using the token sent to their inbox.",
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "example": "abc123def456" },
            "description": "Verification token from the email link"
          }
        ],
        "responses": {
          "200": {
            "description": "Email verified successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": { "type": "string", "example": "" },
                    "message": { "type": "string", "example": "Email verified! You can now log in." }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid or expired token",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" },
                "example": { "error": "Invalid or expired token" }
              }
            }
          }
        }
      }
    },
    "/api/users/forgot-password": {
      "post": {
        "summary": "Request password reset",
        "description": "Sends a password reset email if the email exists. Always returns success to prevent email enumeration.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "example": "johndoe@example.com" }
                },
                "required": ["email"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Reset email sent (if account exists)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": { "type": "string", "example": "" },
                    "message": { "type": "string", "example": "If that email exists, a reset link has been sent." }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/users/google": {
      "post": {
        "summary": "Sign in or register with Google",
        "description": "Verifies a Google ID token (from Google Identity Services on the frontend) and either creates a new account or logs in an existing user. New Google accounts are auto-verified (no email verification step).",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "credential": { "type": "string", "description": "The Google ID token (JWT) returned by Google Identity Services on the frontend" }
                },
                "required": ["credential"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Signed in",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": { "type": "string", "example": "" },
                    "username": { "type": "string", "example": "johndoe" },
                    "email": { "type": "string", "example": "johndoe@gmail.com" }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Missing or invalid Google credential",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" },
                "example": { "error": "Invalid Google token" }
              }
            }
          },
          "500": {
            "description": "Server error or GOOGLE_CLIENT_ID env var missing",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" },
                "example": { "error": "Google auth not configured" }
              }
            }
          }
        }
      }
    },
    "/api/users/reset-password": {
      "post": {
        "summary": "Reset password",
        "description": "Resets the user's password using a valid reset token from the email.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "token": { "type": "string", "example": "abc123def456", "description": "Reset token from the email link" },
                  "newPassword": { "type": "string", "example": "mynewpassword123" }
                },
                "required": ["token", "newPassword"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Password reset successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": { "type": "string", "example": "" },
                    "message": { "type": "string", "example": "Password reset successful! You can now log in." }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid or expired reset token",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" },
                "example": { "error": "Invalid or expired reset token" }
              }
            }
          }
        }
      }
    },
    "/api/posts": {
      "get": {
        "summary": "Get all posts (paginated)",
        "description": "Returns posts sorted by newest first. Each post includes a commentCount field.",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "default": 1, "example": 1 },
            "description": "Page number"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "default": 20, "maximum": 100, "example": 20 },
            "description": "Posts per page (max 100)"
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of posts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "posts": { "type": "array", "items": { "$ref": "#/components/schemas/Post" } },
                    "total": { "type": "integer", "example": 1 },
                    "page": { "type": "integer", "example": 1 },
                    "limit": { "type": "integer", "example": 20 }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create a post",
        "description": "Creates a new blog post. Tags are auto-generated from the title and content (top 5 keywords).",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": { "type": "string", "example": "My First Blog Post" },
                  "content": { "type": "string", "example": "This is the body of the blog post about web development." },
                  "creator": { "type": "string", "example": "johndoe", "description": "Username of the author" }
                },
                "required": ["title", "content", "creator"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Post created successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Post" }
              }
            }
          },
          "400": {
            "description": "Missing required fields (title, content, or creator)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" },
                "example": { "error": "title, content, and creator are required" }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          }
        }
      }
    },
    "/api/posts/search": {
      "get": {
        "summary": "Search posts",
        "description": "Searches posts by title, content, and tags. Case-insensitive.",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "example": "javascript" },
            "description": "Search term"
          }
        ],
        "responses": {
          "200": {
            "description": "Array of matching posts",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Post" } }
              }
            }
          },
          "400": {
            "description": "Missing search query",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" },
                "example": { "error": "missing search query" }
              }
            }
          }
        }
      }
    },
    "/api/posts/filter-by-scores": {
      "get": {
        "summary": "Filter posts by analyzer score ranges",
        "description": "Returns posts whose stored analyzer scores fall inside the requested inclusive ranges. Missing score labels do not exclude a post.",
        "parameters": [
          {
            "name": "scoreFilters",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "example": "[{\"label\":\"optimism\",\"range\":[0.5,0.8]},{\"label\":\"nsfw\",\"range\":[0.0,0.3]}]"
            },
            "description": "JSON-encoded array of score filters"
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "default": 1, "example": 1 },
            "description": "Page number"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "default": 20, "maximum": 100, "example": 20 },
            "description": "Posts per page (max 100)"
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of filtered posts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "posts": { "type": "array", "items": { "$ref": "#/components/schemas/Post" } },
                    "total": { "type": "integer", "example": 1 },
                    "page": { "type": "integer", "example": 1 },
                    "limit": { "type": "integer", "example": 20 }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid scoreFilters query",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" },
                "example": { "error": "scoreFilters must be valid JSON" }
              }
            }
          }
        }
      }
    },
    "/api/posts/tag/{tag}": {
      "get": {
        "summary": "Get posts by tag",
        "description": "Returns all posts that have the specified tag.",
        "parameters": [
          {
            "name": "tag",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "example": "javascript" },
            "description": "Tag to filter by"
          }
        ],
        "responses": {
          "200": {
            "description": "Array of posts with that tag",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Post" } }
              }
            }
          }
        }
      }
    },
    "/api/posts/user/{username}": {
      "get": {
        "summary": "Get posts by user",
        "description": "Returns all posts created by the specified username.",
        "parameters": [
          {
            "name": "username",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "example": "johndoe" },
            "description": "Username of the post creator"
          }
        ],
        "responses": {
          "200": {
            "description": "Array of posts by that user",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Post" } }
              }
            }
          }
        }
      }
    },
    "/api/posts/{id}": {
      "get": {
        "summary": "Get a single post",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "example": "663f1a2b4e12a84f5c9d0e7a" },
            "description": "MongoDB ObjectId of the post (24-character hex string)"
          }
        ],
        "responses": {
          "200": {
            "description": "Post object",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Post" }
              }
            }
          },
          "400": {
            "description": "Invalid ObjectId format",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" },
                "example": { "error": "invalid id" }
              }
            }
          },
          "404": {
            "description": "Post not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" },
                "example": { "error": "post not found" }
              }
            }
          }
        }
      },
      "put": {
        "summary": "Edit a post",
        "description": "Updates a post. The creator field must match the original post creator or you get a 403. Tags are regenerated on edit.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "example": "663f1a2b4e12a84f5c9d0e7a" },
            "description": "MongoDB ObjectId of the post (24-character hex string)"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": { "type": "string", "example": "Updated Blog Post Title" },
                  "content": { "type": "string", "example": "This is the updated body of the blog post." },
                  "creator": { "type": "string", "example": "johndoe", "description": "Must match the original post creator" }
                },
                "required": ["title", "content", "creator"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated post",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Post" }
              }
            }
          },
          "400": {
            "description": "Invalid id or missing required fields",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "403": {
            "description": "Creator does not match original post author",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" },
                "example": { "error": "not authorized" }
              }
            }
          },
          "404": {
            "description": "Post not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" },
                "example": { "error": "post not found" }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Delete a post",
        "description": "Deletes a post and all of its comments.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "example": "663f1a2b4e12a84f5c9d0e7a" },
            "description": "MongoDB ObjectId of the post (24-character hex string)"
          }
        ],
        "responses": {
          "200": {
            "description": "Post deleted successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" },
                "example": { "error": "" }
              }
            }
          },
          "400": {
            "description": "Invalid ObjectId format",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" },
                "example": { "error": "invalid id" }
              }
            }
          },
          "404": {
            "description": "Post not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" },
                "example": { "error": "post not found" }
              }
            }
          }
        }
      }
    },
    "/api/comments": {
      "post": {
        "summary": "Add a comment to a post",
        "description": "Creates a comment on an existing post. Returns 404 if the post does not exist.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "postId": { "type": "string", "example": "663f1a2b4e12a84f5c9d0e7a", "description": "MongoDB ObjectId of the post to comment on" },
                  "creator": { "type": "string", "example": "janedoe", "description": "Username of the commenter" },
                  "content": { "type": "string", "example": "Great post, very helpful!" }
                },
                "required": ["postId", "creator", "content"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Comment created successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Comment" }
              }
            }
          },
          "400": {
            "description": "Missing required fields or invalid postId format",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" }
              }
            }
          },
          "404": {
            "description": "Post not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" },
                "example": { "error": "post not found" }
              }
            }
          }
        }
      }
    },
    "/api/comments/{postId}": {
      "get": {
        "summary": "Get comments for a post",
        "description": "Returns all comments for a post, sorted oldest first.",
        "parameters": [
          {
            "name": "postId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "example": "663f1a2b4e12a84f5c9d0e7a" },
            "description": "MongoDB ObjectId of the post (24-character hex string)"
          }
        ],
        "responses": {
          "200": {
            "description": "Array of comments",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Comment" } }
              }
            }
          },
          "400": {
            "description": "Invalid ObjectId format",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" },
                "example": { "error": "invalid postId" }
              }
            }
          }
        }
      }
    },
    "/api/comments/{id}": {
      "delete": {
        "summary": "Delete a comment",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "example": "663f1b3c5f23b95g6d0e1f8b" },
            "description": "MongoDB ObjectId of the comment (24-character hex string)"
          }
        ],
        "responses": {
          "200": {
            "description": "Comment deleted successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" },
                "example": { "error": "" }
              }
            }
          },
          "400": {
            "description": "Invalid ObjectId format",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" },
                "example": { "error": "invalid id" }
              }
            }
          },
          "404": {
            "description": "Comment not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" },
                "example": { "error": "comment not found" }
              }
            }
          }
        }
      }
    }
  }
}
